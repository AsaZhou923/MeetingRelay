{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-asr-quality-corpus-v1.schema.json",
  "title": "MeetingRelay rights-aware ASR quality corpus v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["corpus_id", "kind", "revision", "samples", "schema_version"],
  "properties": {
    "corpus_id": { "$ref": "#/$defs/identifier" },
    "kind": { "const": "meetingrelay-asr-quality-corpus-v1" },
    "revision": { "type": "integer", "minimum": 1 },
    "samples": { "type": "array", "minItems": 1, "maxItems": 1000, "items": { "$ref": "#/$defs/sample" } },
    "schema_version": { "const": "1.0" }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$" },
    "digest": { "type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$" },
    "relativePath": {
      "type": "string",
      "pattern": "^(?!.*(?:^|/)(?:[Aa][Uu][Xx]|[Cc][Oo][Nn]|[Nn][Uu][Ll]|[Pp][Rr][Nn]|[Cc][Oo][Mm][1-9]|[Ll][Pp][Tt][1-9])(?:\\.|/|$))[A-Za-z0-9](?:[A-Za-z0-9._-]{0,126}[A-Za-z0-9_-])?(?:/[A-Za-z0-9](?:[A-Za-z0-9._-]{0,126}[A-Za-z0-9_-])?)*$",
      "maxLength": 512
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "size_bytes"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "sha256": { "$ref": "#/$defs/digest" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "nonHumanConsent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_purposes", "expires_on", "record_path", "record_sha256", "record_size_bytes", "status", "withdrawn"],
      "properties": {
        "allowed_purposes": { "const": [] },
        "expires_on": { "const": null },
        "record_path": { "const": null },
        "record_sha256": { "const": null },
        "record_size_bytes": { "const": null },
        "status": { "const": "not-required-non-human" },
        "withdrawn": { "const": false }
      }
    },
    "publicLicenseDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_purposes", "expires_on", "record_path", "record_sha256", "record_size_bytes", "status", "withdrawn"],
      "properties": {
        "allowed_purposes": { "const": ["asr-quality-component-measurement"] },
        "expires_on": { "const": null },
        "record_path": { "$ref": "#/$defs/relativePath" },
        "record_sha256": { "$ref": "#/$defs/digest" },
        "record_size_bytes": { "type": "integer", "minimum": 1 },
        "status": { "const": "not-required-public-license" },
        "withdrawn": { "const": false }
      }
    },
    "humanConsent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_purposes", "expires_on", "record_path", "record_sha256", "record_size_bytes", "status", "withdrawn"],
      "properties": {
        "allowed_purposes": { "const": ["asr-quality-component-measurement"] },
        "expires_on": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "record_path": { "$ref": "#/$defs/relativePath" },
        "record_sha256": { "$ref": "#/$defs/digest" },
        "record_size_bytes": { "type": "integer", "minimum": 1 },
        "status": { "const": "verified" },
        "withdrawn": { "const": false }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_purposes", "consent", "license", "retention", "source_kind", "source_url", "status"],
      "properties": {
        "allowed_purposes": { "const": ["asr-quality-component-measurement"] },
        "consent": { "oneOf": [{ "$ref": "#/$defs/nonHumanConsent" }, { "$ref": "#/$defs/publicLicenseDecision" }, { "$ref": "#/$defs/humanConsent" }] },
        "license": { "$ref": "#/$defs/identity" },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expires_on", "status"],
          "properties": {
            "expires_on": { "type": ["string", "null"], "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "status": { "const": "active" }
          }
        },
        "source_kind": { "enum": ["human-consented", "public-corpus", "synthetic"] },
        "source_url": { "const": null },
        "status": { "const": "verified" }
      },
      "allOf": [
        {
          "if": { "properties": { "source_kind": { "const": "synthetic" } }, "required": ["source_kind"] },
          "then": { "properties": { "consent": { "$ref": "#/$defs/nonHumanConsent" } } },
          "else": {
            "if": { "properties": { "source_kind": { "const": "public-corpus" } }, "required": ["source_kind"] },
            "then": { "properties": { "consent": { "$ref": "#/$defs/publicLicenseDecision" } } },
            "else": { "properties": { "consent": { "$ref": "#/$defs/humanConsent" } } }
          }
        }
      ]
    },
    "wav": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bits_per_sample", "channel_count", "duration_samples", "path", "pcm_sha256", "sample_format", "sample_rate_hz", "sha256", "size_bytes"],
      "properties": {
        "bits_per_sample": { "const": 16 },
        "channel_count": { "const": 1 },
        "duration_samples": { "type": "integer", "minimum": 1, "maximum": 33554410 },
        "path": { "$ref": "#/$defs/relativePath" },
        "pcm_sha256": { "$ref": "#/$defs/digest" },
        "sample_format": { "const": "pcm-s16le" },
        "sample_rate_hz": { "const": 16000 },
        "sha256": { "$ref": "#/$defs/digest" },
        "size_bytes": { "type": "integer", "minimum": 46, "maximum": 67108864 }
      }
    },
    "sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["language", "leakage_group_id", "purpose", "reference", "rights", "sample_id", "scenario", "split", "tier", "wav"],
      "properties": {
        "language": { "enum": ["en", "ja", "zh"] },
        "leakage_group_id": { "$ref": "#/$defs/identifier" },
        "purpose": { "const": "asr-quality-component-measurement" },
        "reference": { "$ref": "#/$defs/identity" },
        "rights": { "$ref": "#/$defs/rights" },
        "sample_id": { "$ref": "#/$defs/identifier" },
        "scenario": { "$ref": "#/$defs/identifier" },
        "split": { "enum": ["blind", "calibration", "dev"] },
        "tier": { "const": "tier-1" },
        "wav": { "$ref": "#/$defs/wav" }
      }
    }
  }
}
