{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-fleurs-gold-source-policy-v1.schema.json",
  "title": "MeetingRelay pinned FLEURS source-readiness and deterministic selection policy v1",
  "description": "An engineering source-readiness policy, not legal advice or a claim that participant consent has been cleared. The JavaScript validator is authoritative for canonical JSON, strict UTF-8 TSV parsing, external digest pinning, and selection behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "dataset",
    "kind",
    "rights",
    "schema_version",
    "selection",
    "source_contract_status",
    "sources"
  ],
  "properties": {
    "authority": { "$ref": "#/$defs/authority" },
    "dataset": { "$ref": "#/$defs/dataset" },
    "kind": { "const": "meetingrelay-fleurs-gold-source-policy-v1" },
    "rights": { "$ref": "#/$defs/rights" },
    "schema_version": { "const": "1.0" },
    "selection": { "$ref": "#/$defs/selection" },
    "source_contract_status": { "const": "frozen-source-readiness" },
    "sources": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        { "$ref": "#/$defs/enSource" },
        { "$ref": "#/$defs/jaSource" },
        { "$ref": "#/$defs/zhSource" }
      ],
      "items": false
    }
  },
  "$defs": {
    "nonzeroSha256": {
      "type": "string",
      "pattern": "^(?!0{64}$)[0-9a-f]{64}$"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "benchmark_overlap",
        "evidence_classification",
        "formal_claims",
        "production_evidence",
        "public_distribution",
        "quality_gate_status"
      ],
      "properties": {
        "benchmark_overlap": { "const": "unknown" },
        "evidence_classification": { "const": "internal-descriptive-only" },
        "formal_claims": { "const": "none" },
        "production_evidence": { "const": false },
        "public_distribution": { "const": false },
        "quality_gate_status": { "const": "not-assessed" }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dataset_card", "dataset_id", "revision", "split"],
      "properties": {
        "dataset_card": {
          "type": "object",
          "additionalProperties": false,
          "required": ["repository_path", "sha256", "size_bytes"],
          "properties": {
            "repository_path": { "const": "README.md" },
            "sha256": { "const": "688f79f2a5c731af3796e9f683eb02f9b3f09d040decd8c5625d0f37098e71c6" },
            "size_bytes": { "const": 385614 }
          }
        },
        "dataset_id": { "const": "google/fleurs" },
        "revision": { "const": "70bb2e84b976b7e960aa89f1c648e09c59f894dd" },
        "split": { "const": "test" }
      }
    },
    "rights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_purpose",
        "attribution_required",
        "attribution_url",
        "change_notice_required",
        "citation_url",
        "consent_clearance",
        "decision_scope",
        "decision_status",
        "legal_review",
        "license",
        "license_url",
        "public_distribution"
      ],
      "properties": {
        "allowed_purpose": { "const": "asr-quality-component-measurement" },
        "attribution_required": { "const": true },
        "attribution_url": { "const": "https://huggingface.co/datasets/google/fleurs" },
        "change_notice_required": { "const": true },
        "citation_url": { "const": "https://arxiv.org/abs/2205.12446" },
        "consent_clearance": { "const": "upstream-undocumented" },
        "decision_scope": { "const": "engineering-policy-not-legal-advice" },
        "decision_status": { "const": "approved-with-conditions" },
        "legal_review": { "const": "not-performed" },
        "license": { "const": "CC-BY-4.0" },
        "license_url": { "const": "https://creativecommons.org/licenses/by/4.0/" },
        "public_distribution": { "const": false }
      }
    },
    "selection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["common_id_count", "filename_tie_breaker", "selected_utterance_count"],
      "properties": {
        "common_id_count": { "const": 320 },
        "filename_tie_breaker": { "const": "sha256-utf8-lexicographic-ascending" },
        "selected_utterance_count": { "const": 960 }
      }
    },
    "archive": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lfs_sha256", "repository_path", "size_bytes"],
      "properties": {
        "lfs_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "repository_path": { "type": "string", "minLength": 1 },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "tsv": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository_path", "row_count", "sha256", "size_bytes"],
      "properties": {
        "repository_path": { "type": "string", "minLength": 1 },
        "row_count": { "type": "integer", "minimum": 1 },
        "sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "enSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "language", "test_archive", "test_tsv"],
      "properties": {
        "config": { "const": "en_us" },
        "language": { "const": "en" },
        "test_archive": {
          "allOf": [
            { "$ref": "#/$defs/archive" },
            { "properties": { "lfs_sha256": { "const": "d9c2e37b41aacd41bc283554a0a82b5476b36887049774ecb2819dcaaa55a356" }, "repository_path": { "const": "data/en_us/audio/test.tar.gz" }, "size_bytes": { "const": 289851356 } } }
          ]
        },
        "test_tsv": {
          "allOf": [
            { "$ref": "#/$defs/tsv" },
            { "properties": { "repository_path": { "const": "data/en_us/test.tsv" }, "row_count": { "const": 647 }, "sha256": { "const": "74c046239374deeb60fa63f258f907388093a32bcaa3140965f70ef05c79f7ca" }, "size_bytes": { "const": 367864 } } }
          ]
        }
      }
    },
    "jaSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "language", "test_archive", "test_tsv"],
      "properties": {
        "config": { "const": "ja_jp" },
        "language": { "const": "ja" },
        "test_archive": {
          "allOf": [
            { "$ref": "#/$defs/archive" },
            { "properties": { "lfs_sha256": { "const": "5de465fa7aaafc4e2c13aba44771550b8cd2dd29bb9b265daeb6d92ca8e0c136" }, "repository_path": { "const": "data/ja_jp/audio/test.tar.gz" }, "size_bytes": { "const": 448762391 } } }
          ]
        },
        "test_tsv": {
          "allOf": [
            { "$ref": "#/$defs/tsv" },
            { "properties": { "repository_path": { "const": "data/ja_jp/test.tsv" }, "row_count": { "const": 650 }, "sha256": { "const": "5dd9643511437414681ad3f23508596c621cdf78978724a09f1f06fefe9d300b" }, "size_bytes": { "const": 361174 } } }
          ]
        }
      }
    },
    "zhSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["config", "language", "test_archive", "test_tsv"],
      "properties": {
        "config": { "const": "cmn_hans_cn" },
        "language": { "const": "zh" },
        "test_archive": {
          "allOf": [
            { "$ref": "#/$defs/archive" },
            { "properties": { "lfs_sha256": { "const": "09d19ad18f5d7e91076880807e866cd16abd924c7052b55f71cdae91714fc166" }, "repository_path": { "const": "data/cmn_hans_cn/audio/test.tar.gz" }, "size_bytes": { "const": 525346466 } } }
          ]
        },
        "test_tsv": {
          "allOf": [
            { "$ref": "#/$defs/tsv" },
            { "properties": { "repository_path": { "const": "data/cmn_hans_cn/test.tsv" }, "row_count": { "const": 945 }, "sha256": { "const": "5734461648f816181d7dab5fc79204b18c4b9bc2cd5138225b25c72d18385d21" }, "size_bytes": { "const": 491487 } } }
          ]
        }
      }
    },
    "rightsDecision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_purpose",
        "attribution_required",
        "attribution_url",
        "change_notice_required",
        "citation_url",
        "consent_clearance",
        "dataset_card_sha256",
        "dataset_card_size_bytes",
        "dataset_id",
        "dataset_revision",
        "decision_scope",
        "decision_status",
        "kind",
        "legal_review",
        "license",
        "license_url",
        "policy_sha256",
        "public_distribution",
        "schema_version",
        "source_contract_status"
      ],
      "properties": {
        "allowed_purpose": { "const": "asr-quality-component-measurement" },
        "attribution_required": { "const": true },
        "attribution_url": { "const": "https://huggingface.co/datasets/google/fleurs" },
        "change_notice_required": { "const": true },
        "citation_url": { "const": "https://arxiv.org/abs/2205.12446" },
        "consent_clearance": { "const": "upstream-undocumented" },
        "dataset_card_sha256": { "const": "688f79f2a5c731af3796e9f683eb02f9b3f09d040decd8c5625d0f37098e71c6" },
        "dataset_card_size_bytes": { "const": 385614 },
        "dataset_id": { "const": "google/fleurs" },
        "dataset_revision": { "const": "70bb2e84b976b7e960aa89f1c648e09c59f894dd" },
        "decision_scope": { "const": "engineering-policy-not-legal-advice" },
        "decision_status": { "const": "approved-with-conditions" },
        "kind": { "const": "meetingrelay-fleurs-rights-decision-v1" },
        "legal_review": { "const": "not-performed" },
        "license": { "const": "CC-BY-4.0" },
        "license_url": { "const": "https://creativecommons.org/licenses/by/4.0/" },
        "policy_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "public_distribution": { "const": false },
        "schema_version": { "const": "1.0" },
        "source_contract_status": { "const": "frozen-source-readiness" }
      }
    },
    "privateSelectionEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "config",
        "filename",
        "filename_sha256",
        "language",
        "num_samples",
        "reference",
        "reference_sha256",
        "reference_utf8_bytes",
        "sequence",
        "source_id"
      ],
      "properties": {
        "config": { "enum": ["en_us", "ja_jp", "cmn_hans_cn"] },
        "filename": { "type": "string", "pattern": "^[1-9][0-9]{0,19}\\.wav$" },
        "filename_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "language": { "enum": ["en", "ja", "zh"] },
        "num_samples": { "type": "integer", "minimum": 1, "maximum": 100000000 },
        "reference": {
          "type": "string",
          "minLength": 1,
          "description": "Private normalized FLEURS transcription; forbidden from the text-free projection. The JavaScript validator additionally enforces NFC and exact UTF-8 byte limits."
        },
        "reference_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "reference_utf8_bytes": { "type": "integer", "minimum": 1, "maximum": 65536 },
        "sequence": { "type": "integer", "minimum": 1, "maximum": 960 },
        "source_id": { "type": "string", "pattern": "^[1-9][0-9]{0,19}$" }
      }
    },
    "privateSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "common_id_count",
        "dataset",
        "kind",
        "policy_sha256",
        "rights_decision_sha256",
        "schema_version",
        "selected_utterance_count",
        "selections",
        "source_contract_status"
      ],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "common_id_count": { "const": 320 },
        "dataset": { "$ref": "#/$defs/dataset" },
        "kind": { "const": "meetingrelay-fleurs-gold-source-private-selection-v1" },
        "policy_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "rights_decision_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "schema_version": { "const": "1.0" },
        "selected_utterance_count": { "const": 960 },
        "selections": {
          "type": "array",
          "minItems": 960,
          "maxItems": 960,
          "items": { "$ref": "#/$defs/privateSelectionEntry" }
        },
        "source_contract_status": { "const": "frozen-source-readiness" }
      }
    },
    "projectionSource": {
      "type": "object",
      "additionalProperties": false,
      "description": "Text-free source identity: classifications, counts, sizes, and digests only; no URL, repository path, filename, gender, or transcript fields.",
      "required": [
        "config",
        "language",
        "selected_utterance_count",
        "test_archive_lfs_sha256",
        "test_archive_size_bytes",
        "test_tsv_row_count",
        "test_tsv_sha256",
        "test_tsv_size_bytes"
      ],
      "properties": {
        "config": { "enum": ["en_us", "ja_jp", "cmn_hans_cn"] },
        "language": { "enum": ["en", "ja", "zh"] },
        "selected_utterance_count": { "const": 320 },
        "test_archive_lfs_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "test_archive_size_bytes": { "type": "integer", "minimum": 1 },
        "test_tsv_row_count": { "type": "integer", "minimum": 1 },
        "test_tsv_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "test_tsv_size_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "textFreeProjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "common_id_count",
        "dataset_card_sha256",
        "dataset_card_size_bytes",
        "kind",
        "policy_sha256",
        "rights_decision_sha256",
        "schema_version",
        "selected_utterance_count",
        "selection_sha256",
        "source_contract_status",
        "sources"
      ],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "common_id_count": { "const": 320 },
        "dataset_card_sha256": { "const": "688f79f2a5c731af3796e9f683eb02f9b3f09d040decd8c5625d0f37098e71c6" },
        "dataset_card_size_bytes": { "const": 385614 },
        "kind": { "const": "meetingrelay-fleurs-gold-source-text-free-projection-v1" },
        "policy_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "rights_decision_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "schema_version": { "const": "1.0" },
        "selected_utterance_count": { "const": 960 },
        "selection_sha256": { "$ref": "#/$defs/nonzeroSha256" },
        "source_contract_status": { "const": "frozen-source-readiness" },
        "sources": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/projectionSource" }
        }
      }
    }
  }
}
