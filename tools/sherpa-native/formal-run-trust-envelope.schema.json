{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-formal-run-trust-envelope-v1.schema.json",
  "title": "MeetingRelay formal-run trust records v1",
  "description": "Text-free metadata contracts for a Windows controlled root, a locally orchestrated Release quality-host build, finite retention, handle-bound cleanup, and materialization-only readiness. JavaScript and native validators remain authoritative.",
  "oneOf": [
    { "$ref": "#/$defs/policy" },
    { "$ref": "#/$defs/rootAttestation" },
    { "$ref": "#/$defs/buildAttestation" },
    { "$ref": "#/$defs/createReceipt" },
    { "$ref": "#/$defs/deleteReceipt" },
    { "$ref": "#/$defs/readiness" }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^(?!0{64}$)[0-9a-f]{64}$"
    },
    "commit": {
      "type": "string",
      "pattern": "^(?!0{40}$)[0-9a-f]{40}$"
    },
    "fileId": {
      "type": "string",
      "pattern": "^(?!0{32}$)[0-9a-f]{32}$"
    },
    "positiveDecimal": {
      "type": "string",
      "pattern": "^[1-9][0-9]{0,19}$"
    },
    "utcSeconds": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-([0-2][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$"
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_status",
        "formal_claims",
        "materialization_status",
        "production_evidence",
        "public_distribution",
        "quality_gate_status"
      ],
      "properties": {
        "execution_status": { "const": "not-run" },
        "formal_claims": { "const": "none" },
        "materialization_status": { "const": "not-run" },
        "production_evidence": { "const": false },
        "public_distribution": { "const": false },
        "quality_gate_status": { "const": "not-assessed" }
      }
    },
    "ace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["inheritance", "inherited", "principal", "rights", "type"],
      "properties": {
        "inheritance": { "const": "container-and-object" },
        "inherited": { "const": false },
        "principal": { "enum": ["administrators", "operator", "system"] },
        "rights": { "const": "full-control" },
        "type": { "const": "allow" }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "controlled_root",
        "kind",
        "quality_host",
        "retention",
        "schema_version"
      ],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "controlled_root": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "allowed_aces",
            "dacl_protected",
            "drive_type",
            "filesystem",
            "maximum_inventory_entries",
            "owner_principal",
            "reparse_policy"
          ],
          "properties": {
            "allowed_aces": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "prefixItems": [
                { "allOf": [{ "$ref": "#/$defs/ace" }, { "properties": { "principal": { "const": "administrators" } } }] },
                { "allOf": [{ "$ref": "#/$defs/ace" }, { "properties": { "principal": { "const": "operator" } } }] },
                { "allOf": [{ "$ref": "#/$defs/ace" }, { "properties": { "principal": { "const": "system" } } }] }
              ],
              "items": false
            },
            "dacl_protected": { "const": true },
            "drive_type": { "const": "fixed" },
            "filesystem": { "const": "NTFS" },
            "maximum_inventory_entries": { "const": 4096 },
            "owner_principal": { "const": "operator" },
            "reparse_policy": { "const": "reject-any-tag" }
          }
        },
        "kind": { "const": "meetingrelay-formal-run-trust-policy-v1" },
        "quality_host": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "executable_filename",
            "features",
            "pe_format",
            "pe_machine",
            "pe_subsystem",
            "profile",
            "target"
          ],
          "properties": {
            "executable_filename": { "const": "meetingrelay-sherpa-candidate-quality-host.exe" },
            "features": {
              "const": ["native-quality-sample", "native-sherpa"]
            },
            "pe_format": { "const": "PE32+" },
            "pe_machine": { "const": "amd64" },
            "pe_subsystem": { "const": "console" },
            "profile": { "const": "release" },
            "target": { "const": "x86_64-pc-windows-msvc" }
          }
        },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["maximum_seconds", "mode"],
          "properties": {
            "maximum_seconds": { "const": 2592000 },
            "mode": { "const": "finite-required" }
          }
        },
        "schema_version": { "const": "1.0" }
      }
    },
    "rootAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "inventory", "kind", "root", "schema_version"],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "inventory": {
          "type": "object",
          "additionalProperties": false,
          "required": ["entries", "entry_count", "sha256"],
          "properties": {
            "entries": {
              "type": "array",
              "maxItems": 4096,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["file_id_128", "relative_path_sha256", "reparse_tag"],
                "properties": {
                  "file_id_128": { "$ref": "#/$defs/fileId" },
                  "relative_path_sha256": { "$ref": "#/$defs/sha256" },
                  "reparse_tag": { "type": "null" }
                }
              }
            },
            "entry_count": { "type": "integer", "minimum": 0, "maximum": 4096 },
            "sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "kind": { "const": "meetingrelay-controlled-root-native-attestation-v1" },
        "root": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "aces",
            "dacl_protected",
            "drive_type",
            "file_id_128",
            "filesystem",
            "operator_sid_sha256",
            "owner_principal",
            "reparse_tag",
            "retention_expires_at",
            "root_path_sha256",
            "security_descriptor_sha256",
            "volume_serial_number"
          ],
          "properties": {
            "aces": {
              "type": "array",
              "minItems": 3,
              "maxItems": 3,
              "items": { "$ref": "#/$defs/ace" }
            },
            "dacl_protected": { "const": true },
            "drive_type": { "const": "fixed" },
            "file_id_128": { "$ref": "#/$defs/fileId" },
            "filesystem": { "const": "NTFS" },
            "operator_sid_sha256": { "$ref": "#/$defs/sha256" },
            "owner_principal": { "const": "operator" },
            "reparse_tag": { "type": "null" },
            "retention_expires_at": { "$ref": "#/$defs/utcSeconds" },
            "root_path_sha256": { "$ref": "#/$defs/sha256" },
            "security_descriptor_sha256": { "$ref": "#/$defs/sha256" },
            "volume_serial_number": { "$ref": "#/$defs/positiveDecimal" }
          }
        },
        "schema_version": { "const": "1.0" }
      }
    },
    "buildAttestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["authority", "cargo", "executable", "kind", "schema_version", "source", "toolchain"],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "cargo": {
          "type": "object",
          "additionalProperties": false,
          "required": ["features", "lock_sha256", "profile"],
          "properties": {
            "features": { "const": ["native-quality-sample", "native-sherpa"] },
            "lock_sha256": { "$ref": "#/$defs/sha256" },
            "profile": { "const": "release" }
          }
        },
        "executable": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "filename",
            "imports",
            "pe_format",
            "pe_machine",
            "pe_subsystem",
            "required_dll_characteristics",
            "runtime_bundle_sha256",
            "sha256",
            "size_bytes"
          ],
          "properties": {
            "filename": { "const": "meetingrelay-sherpa-candidate-quality-host.exe" },
            "imports": {
              "type": "array",
              "minItems": 1,
              "maxItems": 64,
              "uniqueItems": true,
              "contains": { "const": "sherpa-onnx-c-api.dll" },
              "items": { "type": "string", "pattern": "^[a-z0-9._-]+\\.dll$" }
            },
            "pe_format": { "const": "PE32+" },
            "pe_machine": { "const": "amd64" },
            "pe_subsystem": { "const": "console" },
            "required_dll_characteristics": {
              "const": ["DYNAMIC_BASE", "GUARD_CF", "HIGH_ENTROPY_VA", "NX_COMPAT"]
            },
            "runtime_bundle_sha256": { "$ref": "#/$defs/sha256" },
            "sha256": { "$ref": "#/$defs/sha256" },
            "size_bytes": { "type": "integer", "minimum": 1 }
          }
        },
        "kind": { "const": "meetingrelay-quality-host-source-build-attestation-v1" },
        "schema_version": { "const": "1.0" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commit", "tree_sha256", "worktree_status"],
          "properties": {
            "commit": { "$ref": "#/$defs/commit" },
            "tree_sha256": { "$ref": "#/$defs/sha256" },
            "worktree_status": { "const": "clean" }
          }
        },
        "toolchain": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cargo_executable_sha256",
            "cargo_v_sha256",
            "git_executable_sha256",
            "rustc_executable_sha256",
            "rustc_vv_sha256",
            "target"
          ],
          "properties": {
            "cargo_executable_sha256": { "$ref": "#/$defs/sha256" },
            "cargo_v_sha256": { "$ref": "#/$defs/sha256" },
            "git_executable_sha256": { "$ref": "#/$defs/sha256" },
            "rustc_executable_sha256": { "$ref": "#/$defs/sha256" },
            "rustc_vv_sha256": { "$ref": "#/$defs/sha256" },
            "target": { "const": "x86_64-pc-windows-msvc" }
          }
        }
      }
    },
    "rootIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["file_id_128", "security_descriptor_sha256", "volume_serial_number"],
      "properties": {
        "file_id_128": { "$ref": "#/$defs/fileId" },
        "security_descriptor_sha256": { "$ref": "#/$defs/sha256" },
        "volume_serial_number": { "$ref": "#/$defs/positiveDecimal" }
      }
    },
    "createReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_identity",
        "authority",
        "created_at",
        "kind",
        "policy_sha256",
        "receipt_scope",
        "retention_expires_at",
        "root_identity",
        "schema_version"
      ],
      "properties": {
        "artifact_identity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "content_sha256",
            "file_id_128",
            "hard_link_count",
            "relative_name_sha256",
            "size_bytes"
          ],
          "properties": {
            "content_sha256": { "$ref": "#/$defs/sha256" },
            "file_id_128": { "$ref": "#/$defs/fileId" },
            "hard_link_count": { "const": 1 },
            "relative_name_sha256": { "$ref": "#/$defs/sha256" },
            "size_bytes": { "type": "integer", "minimum": 1 }
          }
        },
        "authority": { "$ref": "#/$defs/authority" },
        "created_at": { "$ref": "#/$defs/utcSeconds" },
        "kind": { "const": "meetingrelay-controlled-root-create-receipt-v1" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "receipt_scope": {
          "enum": ["controlled-artifact-ownership", "formal-readiness-capability-probe"]
        },
        "retention_expires_at": { "$ref": "#/$defs/utcSeconds" },
        "root_identity": { "$ref": "#/$defs/rootIdentity" },
        "schema_version": { "const": "1.0" }
      }
    },
    "deleteReceipt": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "cleanup",
        "create_receipt_sha256",
        "deleted_at",
        "kind",
        "policy_sha256",
        "receipt_scope",
        "schema_version"
      ],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "cleanup": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "content_sha256",
            "deleted_file_id_128",
            "deletion_method",
            "link_count_before",
            "relative_name_sha256",
            "replacement_status",
            "secure_erase",
            "size_bytes",
            "volume_serial_number"
          ],
          "properties": {
            "content_sha256": { "$ref": "#/$defs/sha256" },
            "deleted_file_id_128": { "$ref": "#/$defs/fileId" },
            "deletion_method": { "const": "set-file-information-by-handle" },
            "link_count_before": { "const": 1 },
            "relative_name_sha256": { "$ref": "#/$defs/sha256" },
            "replacement_status": { "const": "not-present" },
            "secure_erase": { "const": false },
            "size_bytes": { "type": "integer", "minimum": 1 },
            "volume_serial_number": { "$ref": "#/$defs/positiveDecimal" }
          }
        },
        "create_receipt_sha256": { "$ref": "#/$defs/sha256" },
        "deleted_at": { "$ref": "#/$defs/utcSeconds" },
        "kind": { "const": "meetingrelay-controlled-root-delete-receipt-v1" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "receipt_scope": {
          "enum": ["formal-readiness-capability-probe", "retention-enforced-cleanup"]
        },
        "schema_version": { "const": "1.0" }
      }
    },
    "readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authority",
        "controlled_root",
        "kind",
        "policy_sha256",
        "quality_host",
        "readiness_status",
        "retention",
        "schema_version",
        "source"
      ],
      "properties": {
        "authority": { "$ref": "#/$defs/authority" },
        "controlled_root": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attestation_sha256",
            "create_receipt_sha256",
            "delete_receipt_sha256",
            "file_id_128",
            "inventory_entry_count",
            "inventory_sha256",
            "volume_serial_number"
          ],
          "properties": {
            "attestation_sha256": { "$ref": "#/$defs/sha256" },
            "create_receipt_sha256": { "$ref": "#/$defs/sha256" },
            "delete_receipt_sha256": { "$ref": "#/$defs/sha256" },
            "file_id_128": { "$ref": "#/$defs/fileId" },
            "inventory_entry_count": { "type": "integer", "minimum": 0, "maximum": 4096 },
            "inventory_sha256": { "$ref": "#/$defs/sha256" },
            "volume_serial_number": { "$ref": "#/$defs/positiveDecimal" }
          }
        },
        "kind": { "const": "meetingrelay-formal-run-readiness-envelope-v1" },
        "policy_sha256": { "$ref": "#/$defs/sha256" },
        "quality_host": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "build_attestation_sha256",
            "executable_sha256",
            "imports_sha256",
            "pe_hardening_status",
            "runtime_bundle_sha256",
            "source_commit",
            "source_tree_sha256",
            "toolchain_sha256"
          ],
          "properties": {
            "build_attestation_sha256": { "$ref": "#/$defs/sha256" },
            "executable_sha256": { "$ref": "#/$defs/sha256" },
            "imports_sha256": { "$ref": "#/$defs/sha256" },
            "pe_hardening_status": { "const": "required-flags-present" },
            "runtime_bundle_sha256": { "$ref": "#/$defs/sha256" },
            "source_commit": { "$ref": "#/$defs/commit" },
            "source_tree_sha256": { "$ref": "#/$defs/sha256" },
            "toolchain_sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "readiness_status": { "const": "ready-for-materialization-only" },
        "retention": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expires_at", "maximum_seconds", "validated_at"],
          "properties": {
            "expires_at": { "$ref": "#/$defs/utcSeconds" },
            "maximum_seconds": { "const": 2592000 },
            "validated_at": { "$ref": "#/$defs/utcSeconds" }
          }
        },
        "schema_version": { "const": "1.0" },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "common_id_count",
            "configs",
            "dataset_id",
            "policy_sha256",
            "revision",
            "selected_utterance_count",
            "source_contract_status",
            "split"
          ],
          "properties": {
            "common_id_count": { "const": 320 },
            "configs": { "const": ["en_us", "ja_jp", "cmn_hans_cn"] },
            "dataset_id": { "const": "google/fleurs" },
            "policy_sha256": { "const": "9a659b87a5c12dacf749226d6c51a7be1edbb98c6fae313293c985cbeda1da2c" },
            "revision": { "const": "70bb2e84b976b7e960aa89f1c648e09c59f894dd" },
            "selected_utterance_count": { "const": 960 },
            "source_contract_status": { "const": "frozen-source-readiness" },
            "split": { "const": "test" }
          }
        }
      }
    }
  }
}
