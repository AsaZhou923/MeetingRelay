{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-native-candidate-component-evidence-v1.schema.json",
  "title": "MeetingRelay text-free native candidate component evidence foundation v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["assessment_status", "authority", "candidate_identity", "corpus_identity", "execution_host_identity", "kind", "limitations", "results", "schema_version"],
  "properties": {
    "assessment_status": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_status", "parent_closeout_status", "quality_status", "ranking_status", "selection_status", "threshold_status"],
      "properties": {
        "default_status": { "const": "not-authorized" },
        "parent_closeout_status": { "const": "not-assessed" },
        "quality_status": { "const": "not-assessed" },
        "ranking_status": { "const": "not-authorized" },
        "selection_status": { "const": "not-authorized" },
        "threshold_status": { "const": "not-frozen" }
      }
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formal_claims", "production_evidence"],
      "properties": {
        "formal_claims": { "const": "none" },
        "production_evidence": { "const": false }
      }
    },
    "candidate_identity": { "$ref": "#/$defs/candidateIdentity" },
    "corpus_identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_sha256", "sample_count", "snapshot_sha256", "validation_date"],
      "properties": {
        "manifest_sha256": { "$ref": "#/$defs/digest" },
        "sample_count": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "snapshot_sha256": { "$ref": "#/$defs/digest" },
        "validation_date": { "$ref": "#/$defs/date" }
      }
    },
    "execution_host_identity": { "$ref": "#/$defs/hostIdentity" },
    "kind": { "const": "meetingrelay-native-candidate-component-evidence-v1" },
    "limitations": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "prefixItems": [
        { "const": "synthetic-contract-foundation-does-not-assess-model-quality" },
        { "const": "component-evidence-excludes-hypothesis-content-and-scores" },
        { "const": "candidate-source-and-hardware-artifacts-not-directly-materialized" },
        { "const": "resource-sampling-unavailable" },
        { "const": "publication-retains-auditable-create-new-staging-residue" },
        { "const": "spawn-path-toctou-not-eliminated-by-node-supervisor" },
        { "const": "thresholds-not-frozen" },
        { "const": "ranking-selection-default-and-parent-closeout-not-authorized" }
      ],
      "items": false
    },
    "results": { "type": "array", "minItems": 1, "maxItems": 1000, "items": { "$ref": "#/$defs/result" } },
    "schema_version": { "const": "1.0" }
  },
  "$defs": {
    "digest": { "type": "string", "pattern": "^(?!0{64}$)[0-9a-f]{64}$" },
    "date": { "type": "string", "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])$" },
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9._-]{1,128}$" },
    "decimal": {
      "type": "string",
      "maxLength": 20,
      "pattern": "^(0|[1-9][0-9]{0,18}|1[0-7][0-9]{18}|18[0-3][0-9]{17}|184[0-3][0-9]{16}|1844[0-5][0-9]{15}|18446[0-6][0-9]{14}|184467[0-3][0-9]{13}|1844674[0-3][0-9]{12}|184467440[0-6][0-9]{10}|1844674407[0-2][0-9]{9}|18446744073[0-6][0-9]{8}|1844674407370[0-8][0-9]{6}|18446744073709[0-4][0-9]{5}|184467440737095[0-4][0-9]{4}|18446744073709550[0-9]{3}|18446744073709551[0-5][0-9]{2}|1844674407370955160[0-9]|1844674407370955161[0-4]|18446744073709551615)$",
      "description": "Canonical decimal in the inclusive uint64 range 0..18446744073709551615."
    },
    "parameterMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["en", "ja", "zh"],
      "properties": {
        "en": { "const": "f411caf1efd92b18b953c3bfd0bf6a4eb49d18068554ce9e70d8a493d325065d" },
        "ja": { "const": "946af178a84c720f928d08ed084fe37625a57447b2ad8e8dc5d36034ea319bf5" },
        "zh": { "const": "0ac8669e387262648fcf05fd301a9ba798bb2822e56ec952f1e17d6c692f802e" }
      }
    },
    "candidateIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset_lock_sha256", "baseline_execution_host", "candidate_id", "candidate_manifest_sha256", "measured_evidence_sha256", "model_sha256", "package_lock_sha256", "parameter_sha256", "parameter_sha256_by_language", "runtime_bundle_sha256", "tokens_sha256"],
      "properties": {
        "asset_lock_sha256": { "$ref": "#/$defs/digest" },
        "baseline_execution_host": { "$ref": "#/$defs/hostIdentity" },
        "candidate_id": { "const": "sherpa-native-sensevoice-int8-2024-07-17-win-x64-cpu" },
        "candidate_manifest_sha256": { "$ref": "#/$defs/digest" },
        "measured_evidence_sha256": { "$ref": "#/$defs/digest" },
        "model_sha256": { "$ref": "#/$defs/digest" },
        "package_lock_sha256": { "$ref": "#/$defs/digest" },
        "parameter_sha256": { "const": "0ac8669e387262648fcf05fd301a9ba798bb2822e56ec952f1e17d6c692f802e" },
        "parameter_sha256_by_language": { "$ref": "#/$defs/parameterMap" },
        "runtime_bundle_sha256": { "$ref": "#/$defs/digest" },
        "tokens_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "hostIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executable_sha256", "schema_registry_sha256"],
      "properties": {
        "executable_sha256": { "$ref": "#/$defs/digest" },
        "schema_registry_sha256": { "$ref": "#/$defs/digest" }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "status"],
      "properties": {
        "reason": { "const": "SHERPA_QUALITY_RESOURCE_SAMPLING_UNAVAILABLE" },
        "status": { "const": "unavailable" }
      }
    },
    "rtf": {
      "type": "object",
      "additionalProperties": false,
      "required": ["denominator_audio_ns", "numerator_execute_ns"],
      "properties": {
        "denominator_audio_ns": { "$ref": "#/$defs/decimal" },
        "numerator_execute_ns": { "$ref": "#/$defs/decimal" }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attempt", "candidate_parameter_sha256", "execute_elapsed_ns", "final_transcript_sha256", "final_transcript_utf8_bytes", "host_record_sha256", "language", "prepare_elapsed_ns", "resources", "rtf", "sample_id", "sample_identity_sha256", "scenario", "sequence", "split", "tier"],
      "properties": {
        "attempt": { "const": 1 },
        "candidate_parameter_sha256": { "$ref": "#/$defs/digest" },
        "execute_elapsed_ns": { "$ref": "#/$defs/decimal" },
        "final_transcript_sha256": { "$ref": "#/$defs/digest" },
        "final_transcript_utf8_bytes": { "$ref": "#/$defs/decimal" },
        "host_record_sha256": { "$ref": "#/$defs/digest" },
        "language": { "enum": ["en", "ja", "zh"] },
        "prepare_elapsed_ns": { "$ref": "#/$defs/decimal" },
        "resources": { "$ref": "#/$defs/resources" },
        "rtf": { "$ref": "#/$defs/rtf" },
        "sample_id": { "$ref": "#/$defs/identifier" },
        "sample_identity_sha256": { "$ref": "#/$defs/digest" },
        "scenario": { "$ref": "#/$defs/identifier" },
        "sequence": { "type": "integer", "minimum": 1, "maximum": 1000 },
        "split": { "enum": ["blind", "calibration", "dev"] },
        "tier": { "const": "tier-1" }
      }
    }
  }
}
