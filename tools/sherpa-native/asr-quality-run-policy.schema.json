{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-asr-quality-run-policy-v1.schema.json",
  "title": "MeetingRelay externally frozen synthetic-mechanics ASR quality run policy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "coverage_scope",
    "exclusion_policy",
    "kind",
    "max_attempts",
    "quality_gate_status",
    "required_slices",
    "schema_version"
  ],
  "properties": {
    "coverage_scope": {
      "const": "synthetic-mechanics-only"
    },
    "exclusion_policy": {
      "const": "none"
    },
    "kind": {
      "const": "meetingrelay-asr-quality-run-policy-v1"
    },
    "max_attempts": {
      "const": 1
    },
    "quality_gate_status": {
      "const": "not-assessed"
    },
    "required_slices": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "items": {
        "$ref": "#/$defs/slice"
      }
    },
    "schema_version": {
      "const": "1.0"
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$"
    },
    "slice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "language",
        "scenario",
        "tier"
      ],
      "properties": {
        "language": {
          "enum": [
            "en",
            "ja",
            "zh"
          ]
        },
        "scenario": {
          "$ref": "#/$defs/identifier"
        },
        "tier": {
          "const": "tier-1"
        }
      }
    }
  }
}
