{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://meetingrelay.local/schemas/meetingrelay-native-candidate-quality-smoke-evidence-v1.schema.json",
  "title": "MeetingRelay native candidate quality smoke evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "authority",
    "input_identity",
    "kind",
    "limitations",
    "quality_gate_status",
    "redistribution_status",
    "reference",
    "runs",
    "schema_version"
  ],
  "properties": {
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["formal_claims", "production_evidence"],
      "properties": {
        "formal_claims": { "const": "none" },
        "production_evidence": { "const": false }
      }
    },
    "input_identity": { "$ref": "#/$defs/inputIdentity" },
    "kind": { "const": "meetingrelay-native-candidate-quality-smoke-evidence-v1" },
    "limitations": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "prefixItems": [
        { "const": "upstream-documented-reference-not-independent-gold" },
        { "const": "audio-redistribution-rights-unresolved" },
        { "const": "meetingrelay-locked-zh-not-upstream-parameter-identical" },
        { "const": "single-reference-exact-match-not-product-quality-assessment" },
        { "const": "performance-and-resource-usage-not-measured" },
        { "const": "selection-default-and-parent-closeout-not-authorized" }
      ],
      "items": false
    },
    "quality_gate_status": { "const": "not-assessed" },
    "redistribution_status": { "const": "unresolved" },
    "reference": { "$ref": "#/$defs/reference" },
    "runs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "prefixItems": [
        {
          "allOf": [
            { "$ref": "#/$defs/run" },
            { "properties": { "run_index": { "const": 1 } } }
          ]
        },
        {
          "allOf": [
            { "$ref": "#/$defs/run" },
            { "properties": { "run_index": { "const": 2 } } }
          ]
        }
      ],
      "items": false
    },
    "schema_version": { "const": "1.0" }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "inputIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_host_sha256",
        "locked_input_snapshot_sha256",
        "reference_manifest_sha256",
        "schema_registry_sha256",
        "wav_sha256"
      ],
      "properties": {
        "execution_host_sha256": { "$ref": "#/$defs/digest" },
        "locked_input_snapshot_sha256": { "$ref": "#/$defs/digest" },
        "reference_manifest_sha256": {
          "const": "cc2afff6bc92a6fe6e2b58e15332422dc3ecddae790eac6235fa543e2bd76590"
        },
        "schema_registry_sha256": { "$ref": "#/$defs/digest" },
        "wav_sha256": {
          "const": "b77f1794fe374a0ba1ee1dc458bfaf9349496cbbfc32780c50ba3c5a7ad8e373"
        }
      }
    },
    "audio": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bits_per_sample",
        "channel_count",
        "codec",
        "data_bytes",
        "duration_milliseconds",
        "file_bytes",
        "sample_frames",
        "sample_rate_hz",
        "sha256"
      ],
      "properties": {
        "bits_per_sample": { "const": 16 },
        "channel_count": { "const": 1 },
        "codec": { "const": "pcm-s16le" },
        "data_bytes": { "const": 178944 },
        "duration_milliseconds": { "const": 5592 },
        "file_bytes": { "const": 178988 },
        "sample_frames": { "const": 89472 },
        "sample_rate_hz": { "const": 16000 },
        "sha256": {
          "const": "b77f1794fe374a0ba1ee1dc458bfaf9349496cbbfc32780c50ba3c5a7ad8e373"
        }
      }
    },
    "transcript": {
      "type": "object",
      "additionalProperties": false,
      "required": ["match_basis", "reference_role", "sha256", "utf8_bytes"],
      "properties": {
        "match_basis": { "const": "sha256-and-utf8-byte-length" },
        "reference_role": {
          "const": "upstream-documented-smoke-reference-not-independent-gold"
        },
        "sha256": {
          "const": "3dcf3d55f672e2d610a031580f924b47ddf147ff3d93f007b8386f9bef8cac58"
        },
        "utf8_bytes": { "const": 38 }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audio",
        "manifest_sha256",
        "transcript",
        "upstream_repository_commit"
      ],
      "properties": {
        "audio": { "$ref": "#/$defs/audio" },
        "manifest_sha256": {
          "const": "cc2afff6bc92a6fe6e2b58e15332422dc3ecddae790eac6235fa543e2bd76590"
        },
        "transcript": { "$ref": "#/$defs/transcript" },
        "upstream_repository_commit": {
          "const": "0166495ed093aeb90f42c99da5f7cf91da1e110d"
        }
      }
    },
    "checkSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["passed", "total"],
      "properties": {
        "passed": { "const": 12 },
        "total": { "const": 12 }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend_execute_calls",
        "check_summary",
        "conformance_record_sha256",
        "exact_reference_match",
        "final_transcript_sha256",
        "final_transcript_utf8_bytes",
        "fresh_process",
        "input_snapshot_sha256",
        "run_index",
        "worker_id"
      ],
      "properties": {
        "backend_execute_calls": { "const": 1 },
        "check_summary": { "$ref": "#/$defs/checkSummary" },
        "conformance_record_sha256": { "$ref": "#/$defs/digest" },
        "exact_reference_match": { "const": true },
        "final_transcript_sha256": {
          "const": "3dcf3d55f672e2d610a031580f924b47ddf147ff3d93f007b8386f9bef8cac58"
        },
        "final_transcript_utf8_bytes": { "const": 38 },
        "fresh_process": { "const": true },
        "input_snapshot_sha256": { "$ref": "#/$defs/digest" },
        "run_index": { "type": "integer", "minimum": 1, "maximum": 2 },
        "worker_id": { "const": "meetingrelay-sherpa-native-candidate-host-v1" }
      }
    }
  }
}
