{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attestor_source_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "built_wheel_count": { "const": 5 },
    "built_wheel_declaration_set_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "candidate_aggregate_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "cpython_provenance_authority": { "const": "none" },
    "distribution_count": { "const": 77 },
    "execution_status": { "const": "offline-install-pip-check-inspect-no-funasr-import" },
    "formal_claims": { "const": "none" },
    "environment_materialization_authority": { "const": "offline-venv-materialized" },
    "four_e_after_evidence_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "four_e_before_evidence_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "four_e_package_lock_role_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "input_scope": { "enum": ["synthetic-valid-wheels-no-real-funasr-code", "caller-supplied-controlled-inputs-not-product-approved"], "type": "string" },
    "import_authority": { "const": "none" },
    "installed_dist_info_contract_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "kind": { "const": "meetingrelay-funasr-sidecar-venv-materialization-attestation-v1" },
    "license_authority": { "const": "none" },
    "limitations": {
      "items": false,
      "maxItems": 7,
      "minItems": 7,
      "prefixItems": [
        { "const": "controlled-wheelhouse-and-venv-materialized-only: this validates a caller-supplied existing 4b-bound virtual environment by installing from a local wheelhouse with pip --no-index and checking installed metadata surfaces; it is not CPython provenance or OS-level network isolation authority" },
        { "const": "runtime target compatibility is limited to the bound interpreter self-reporting CPython 3.12 on 64-bit Windows AMD64 with a win-amd64 platform; binary origin, signature, and CPython provenance remain unverified" },
        { "const": "synthetic CI wheels contain no real FunASR, PyTorch, model, audio, network, or product package code; they exercise materialization mechanics only" },
        { "const": "source_build_authority=none: sdist-derived declarations are checked as a fixed declared set, but source archives and build attestations are not opened, parsed, or replayed" },
        { "const": "license_authority=none and import_authority=none: license target bytes and package imports are not verified by this slice" },
        { "const": "installed RECORD entries must remain inside site-packages in this slice; console-script or data-scheme entries outside site-packages fail closed and are not validated" },
        { "const": "public evidence intentionally omits filesystem paths, artifact filenames, package names, requirement text, URLs, pip output, environment values, timings, host identity, and plaintext" }
      ],
      "type": "array"
    },
    "materialized_environment_report_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "measurement_status": { "const": "controlled-wheelhouse-and-venv-materialized-only" },
    "package_lock_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "package_metadata_authority": { "const": "installed-dist-info-record-verified-only" },
    "packaging_authority": { "const": "controlled-wheelhouse-and-offline-venv-only" },
    "production_evidence": { "const": false },
    "public_distribution": { "const": false },
    "quality_gate_status": { "const": "not-assessed" },
    "root_requirement_count": { "const": 3 },
    "runtime_target_probe_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "schema_file_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
    "schema_version": { "const": "1.0" },
    "selection_authority": { "const": "none" },
    "source_build_authority": { "const": "none" },
    "target": {
      "additionalProperties": false,
      "properties": {
        "accelerator_profile": { "const": "cpu-baseline" },
        "arch": { "const": "amd64" },
        "cpython_version_family": { "const": "3.12.x" },
        "os": { "const": "windows" },
        "platform_tag": { "const": "win_amd64" },
        "python_abi": { "const": "cp312" }
      },
      "required": ["os", "arch", "cpython_version_family", "python_abi", "platform_tag", "accelerator_profile"],
      "type": "object"
    },
    "validator_limits": {
      "additionalProperties": false,
      "properties": {
        "max_process_output_bytes": { "const": 1048576 },
        "max_process_timeout_ms": { "const": 120000 },
        "pip_index_access": { "const": "disabled-by-no-index-and-sanitized-env" },
        "pip_install_flags_sha256": { "pattern": "^[0-9a-f]{64}$", "type": "string" },
        "public_evidence": { "const": "path-url-name-text-free" }
      },
      "required": ["pip_index_access", "max_process_timeout_ms", "max_process_output_bytes", "pip_install_flags_sha256", "public_evidence"],
      "type": "object"
    },
    "wheel_count": { "const": 77 },
    "worker_role": { "const": "sidecar-candidate" }
  },
  "required": [
    "kind",
    "schema_version",
    "schema_file_sha256",
    "attestor_source_sha256",
    "four_e_before_evidence_sha256",
    "four_e_after_evidence_sha256",
    "candidate_aggregate_sha256",
    "package_lock_sha256",
    "four_e_package_lock_role_sha256",
    "measurement_status",
    "execution_status",
    "packaging_authority",
    "environment_materialization_authority",
    "package_metadata_authority",
    "source_build_authority",
    "license_authority",
    "cpython_provenance_authority",
    "import_authority",
    "quality_gate_status",
    "formal_claims",
    "production_evidence",
    "public_distribution",
    "selection_authority",
    "worker_role",
    "input_scope",
    "target",
    "root_requirement_count",
    "distribution_count",
    "wheel_count",
    "built_wheel_count",
    "built_wheel_declaration_set_sha256",
    "installed_dist_info_contract_sha256",
    "materialized_environment_report_sha256",
    "runtime_target_probe_sha256",
    "validator_limits",
    "limitations"
  ],
  "type": "object"
}
