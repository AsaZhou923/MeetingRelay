{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "meetingrelay-funasr-sidecar-wire-foundation.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schema_version",
    "schema_file_sha256",
    "measurement_status",
    "quality_gate_status",
    "execution_status",
    "formal_claims",
    "production_evidence",
    "public_distribution",
    "wire",
    "faults",
    "supervisor",
    "limitations"
  ],
  "properties": {
    "kind": { "const": "meetingrelay-funasr-sidecar-wire-foundation-v1" },
    "schema_version": { "const": "1.0" },
    "schema_file_sha256": { "$ref": "#/$defs/sha256" },
    "measurement_status": { "const": "wire-fault-foundation-only" },
    "quality_gate_status": { "const": "not-assessed" },
    "execution_status": { "const": "mock-sidecar-only" },
    "formal_claims": { "const": "none" },
    "production_evidence": { "const": false },
    "public_distribution": { "const": false },
    "wire": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "magic_sha256",
        "version",
        "max_header_bytes",
        "max_payload_bytes",
        "request_frame_count",
        "response_frame_count",
        "transcript_schema_sha256",
        "transcript_digest_sha256",
        "wire_transcript_preimage_domain",
        "wire_transcript_sha256"
      ],
      "properties": {
        "magic_sha256": { "$ref": "#/$defs/sha256" },
        "version": { "const": 1 },
        "max_header_bytes": { "const": 65536 },
        "max_payload_bytes": { "const": 1048576 },
        "request_frame_count": { "const": 5 },
        "response_frame_count": { "const": 5 },
        "transcript_schema_sha256": { "$ref": "#/$defs/sha256" },
        "transcript_digest_sha256": { "$ref": "#/$defs/sha256" },
        "wire_transcript_preimage_domain": { "const": "meetingrelay.sidecar-wire.transcript.v1" },
        "wire_transcript_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "faults": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered_count", "rows", "observations_sha256"],
      "properties": {
        "covered_count": { "const": 16 },
        "rows": {
          "type": "array",
          "minItems": 16,
          "maxItems": 16,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["case", "observed_code", "status"],
            "properties": {
              "case": {
                "enum": [
                  "bad-length",
                  "bad-magic",
                  "bom",
                  "cr",
                  "extra-after-final",
                  "non-utf8",
                  "nonzero-exit",
                  "nul",
                  "payload-digest",
                  "payload-oversize",
                  "schema-drift",
                  "sequence-duplicate",
                  "sequence-skip",
                  "stderr",
                  "stdout-overflow",
                  "timeout"
                ]
              },
              "observed_code": {
                "pattern": "^SIDECAR_(WIRE|SUPERVISOR)_[A-Z0-9_]+$"
              },
              "status": { "const": "covered" }
            }
          }
        },
        "observations_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "supervisor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command_is_process_exec_path",
        "node_executable_sha256",
        "mock_sidecar_sha256",
        "shell",
        "windowsHide",
        "detached",
        "minimal_environment",
        "path_entries",
        "proxy_environment_forwarded",
        "direct_child_closed"
      ],
      "properties": {
        "command_is_process_exec_path": { "const": true },
        "node_executable_sha256": { "$ref": "#/$defs/sha256" },
        "mock_sidecar_sha256": { "$ref": "#/$defs/sha256" },
        "shell": { "const": false },
        "windowsHide": { "const": true },
        "detached": { "const": false },
        "minimal_environment": { "const": true },
        "path_entries": { "type": "integer", "minimum": 1, "maximum": 2 },
        "proxy_environment_forwarded": { "const": false },
        "direct_child_closed": { "const": true }
      }
    },
    "limitations": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "prefixItems": [
        {
          "const": "mock-sidecar-only: no real FunASR model, Python runtime, model download, real audio, quality threshold, ranking, selection, default, or publication authority is exercised"
        },
        {
          "const": "no heartbeat, progress protocol, restart budget, or recovery scheduler is exercised by this foundation"
        },
        {
          "const": "no source or build attestation is produced by this Node-only mock-sidecar foundation"
        },
        {
          "const": "no Job Object or grandchild containment proof is claimed; only direct child close is observed"
        }
      ],
      "items": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    }
  }
}
