* text=auto eol=lf

*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

*.ico binary
*.icns binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.woff binary
*.woff2 binary
*.pdf binary

# These locked upstream license snapshots are hashed by assets.lock.json.
# Preserve their exact line endings and permit an upstream trailing blank line
# without weakening whitespace checks for the rest of the repository.
tools/sherpa-native/licenses/*.txt -text whitespace=-blank-at-eof
