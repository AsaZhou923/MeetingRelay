{
  "name": "meetingrelay-workspace",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "desktop:dev": "pnpm --dir apps/desktop dev",
    "desktop:build": "pnpm --dir apps/desktop build",
    "desktop:typecheck": "pnpm --dir apps/desktop typecheck",
    "phase0:fixtures:generate": "node tools/phase0-harness/generate-fixtures.mjs",
    "phase0:fixtures:test": "node --test tools/phase0-harness/fixture-contract.test.mjs",
    "phase0:fixtures:validate": "node tools/phase0-harness/validate-fixtures.mjs",
    "phase0:candidate-artifacts:test": "node --test tools/phase0-harness/candidate-artifact-contract.test.mjs",
    "phase0:candidate-artifacts:validate": "node tools/phase0-harness/validate-candidate-artifact-contract.mjs",
    "phase0:hw-ref:test": "node --test tools/phase0-harness/hw-ref-collector.test.mjs",
    "phase0:sherpa-assets:test": "node --test tools/sherpa-native/validate-lock.test.mjs",
    "phase0:sherpa-assets:validate": "node tools/sherpa-native/validate-lock.mjs",
    "phase0:sherpa-provenance:test": "node --test tools/sherpa-native/worker-provenance.test.mjs",
    "phase0:ledgers:test": "node --test tools/phase0-harness/ledger-contract.test.mjs",
    "phase0:ledgers:validate": "node tools/phase0-harness/validate-ledger-replays.mjs",
    "phase0:provider:test": "node --test tools/phase0-harness/provider-harness.test.mjs",
    "phase0:provider:validate": "node tools/phase0-harness/validate-provider-harness.mjs",
    "phase0:clock:test": "node --test tools/phase0-harness/clock-calibration.test.mjs",
    "phase0:clock:validate": "node tools/phase0-harness/validate-clock-calibration.mjs",
    "phase0:resources:test": "node --test tools/phase0-harness/queue-resource-harness.test.mjs",
    "phase0:resources:validate": "node tools/phase0-harness/validate-queue-resource-harness.mjs",
    "tauri": "pnpm --dir apps/desktop tauri"
  }
}
