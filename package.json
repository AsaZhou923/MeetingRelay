{
  "name": "meetingrelay-workspace",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "desktop:dev": "pnpm --dir apps/desktop dev",
    "desktop:build": "pnpm --dir apps/desktop build",
    "desktop:typecheck": "pnpm --dir apps/desktop typecheck",
    "desktop:test": "pnpm --dir apps/desktop test",
    "mvp:release:personal": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File tools/mvp/release.ps1",
    "mvp:release:personal:test": "powershell.exe -NoLogo -NoProfile -ExecutionPolicy Bypass -File tools/mvp/release.test.ps1",
    "tauri": "pnpm --dir apps/desktop tauri"
  }
}
