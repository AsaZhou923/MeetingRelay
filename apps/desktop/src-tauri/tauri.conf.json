{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeetingRelay",
  "version": "0.0.1",
  "identifier": "com.meetingrelay.phase0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeetingRelay · 本地实时转写",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 620,
        "resizable": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost",
        "style-src": "'self'"
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "ipc: http://ipc.localhost http://localhost:1420 ws://localhost:1420",
        "style-src": "'self' 'unsafe-inline'"
      }
    }
  },
  "bundle": {
    "active": false
  }
}
